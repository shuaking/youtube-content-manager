# Environment Variables Template
# Copy this file to .env.local and fill in your actual values

# ==================== YouTube API ====================
# Required: Get from https://console.cloud.google.com/
# Guide: docs/YOUTUBE_API_GUIDE.md
YOUTUBE_API_KEY=your_youtube_api_key_here

# ==================== Supabase (Optional) ====================
# Optional: For cloud database storage
# If not configured, system will use local JSON files
# Guide: docs/SUPABASE_SETUP.md

NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# ==================== Notes ====================
#
# Local Development:
# - Copy this file to .env.local
# - Fill in your actual values
# - Never commit .env.local to Git
#
# Vercel Deployment:
# - Configure these in Vercel Dashboard → Settings → Environment Variables
# - Guide: docs/VERCEL_DEPLOYMENT.md
#
# Security:
# - Keep API keys secret
# - Rotate keys regularly
# - Use different keys for development and production
